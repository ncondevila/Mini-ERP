<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.erp.controller.ClienteController"
            prefWidth="800" prefHeight="600" stylesheets="@../css/estilo.css">
    
    <ScrollPane fx:id="contenedorCliente"
                AnchorPane.topAnchor="10"
                AnchorPane.leftAnchor="10"
                AnchorPane.rightAnchor="10"
                AnchorPane.bottomAnchor="10"
                styleClass="panel-contenido">
        
        <VBox spaciong="10" prefWidth="600">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            
            <Label text="Gestión de Clientes" styleClass="titulo-panel" />
            
            <HBox fx:id="subMenuAcciones" spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10" />
                </padding>
                <Button fx:id="botonAñadirCliente" id="botonAñadirCliente"
                        text="Añadir" prefWidth="100" prefHeight="40"
                        onAction="#mostrarVistaAñadir" styleClass="boton-principal-cliente" />
                <Button fx:id="botonBuscarCliente" id="botonBuscarCliente"
                        text="Buscar" prefWidth="100" prefHeight="40"
                        onAction="#mostrarVistaBuscar" styleClass="boton-principal-cliente" />
            </HBox>
            
            <StackPane fx:id="zonaContenido" VBox.grow="ALWAYS">
                
                <Label fx:id="inicio" managed="true" />
                
                <VBox fx:id="formularioAñadirCliente" id="formularioCliente"
                      spacing="10" prefWidth="600" styleclass="formulario-panel">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10" />
                    </padding>
                    <Label fx:id="tituloFormulario" id="tituloFormulario"
                           text="Formulario añadir Cliente" styleClass="subtitulo-panel" />
                    
                    <ComboBox fx:id="tipoClienteCombo">
                        <items>
                            <FXCollections fx:factory="observableArrayLisst">
                                <String fx:value="Particular">Particular</String>
                                <String fx:value="Empresa">Empresa</String>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    
                    <GridPane hgap="10" vgap="10">
                        
                        <VBox fx:id="grupoparticular" 
                              GridPane.columnIndex="0" GridPane.rowIndex="0"
                              GridPane.columnSpan="2"
                              visible="true" managed="true" spacing="6">
                            
                            <Label text="Nombre - Apellidos: " />
                            <HBox spacing="10">
                                <TextField fx:id="nombre" />
                                <TextField fx:id="apellidos" />
                            </HBox>
                        </VBox>
                        
                        <VBox fx:id="grupoEmpresa" 
                              GridPane.columnIndex="0" GridPane.rowIndex="0"
                            GridPane.columnSpan="2"
                            visible="false" managed="false" spacing="6">
                            
                            <Label text="Razón social - Persona contacto: " />
                            <HBox spacing="10">
                                <TextField fx:id="razonSocialField" />
                                <TextField fx:id="personaContactoField" />
                            </HBox>
                        </VBox>
                        
                        <Label text="Teléfono" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="telefonoField" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="campo-formulario"/>
                        
                        <Label text="Dirección" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="direccionField" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="campo-formulario"/>
                        
                        <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="campo-formulario"/>
                        
                        <Label text="NIF / CIF" Grid.pane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField fx:id="cifNifField" GridPane.columnIndex="1" GridPane.rowIndex="4" styleClass="campo-formulario"/>

                    </GridPane>
                    
                </VBox>
                
            </StackPane>
        </HBox>
        
        
    </VBox>
    
    
    
    
    
    
    
    
    
    
    
    
    
</ScrollPane>       
























</AnchorPane>